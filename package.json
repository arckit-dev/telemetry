{
  "name": "@arckit/telemetry",
  "version": "1.0.0",
  "description": "Vendor-neutral telemetry toolkit — logs, errors, events, traces and metrics behind pluggable adapters (Pino, OpenTelemetry, Sentry, Matomo)",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "author": "Marc Gavanier <marc@gavanier.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arckit-dev/telemetry.git"
  },
  "homepage": "https://github.com/arckit-dev/telemetry#readme",
  "bugs": {
    "url": "https://github.com/arckit-dev/telemetry/issues"
  },
  "keywords": ["arckit", "telemetry", "observability", "opentelemetry", "logging", "metrics", "tracing"],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./context": {
      "import": {
        "types": "./dist/context.d.ts",
        "default": "./dist/context.js"
      },
      "require": {
        "types": "./dist/context.d.cts",
        "default": "./dist/context.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "context": ["dist/context.d.ts"]
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:code": "biome check --write",
    "lint:code:ci": "biome ci",
    "lint:commit": "commitlint --from origin/main",
    "lint:unused": "knip",
    "check:publint": "publint",
    "check:attw": "attw --pack .",
    "check:size": "size-limit",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1",
    "@sentry/nextjs": ">=8",
    "pino": ">=9"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "@sentry/nextjs": {
      "optional": true
    },
    "pino": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@biomejs/biome": "^2.4.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/exec": "^7.0.0",
    "@semantic-release/git": "^10.0.0",
    "@sentry/nextjs": "^10.53.1",
    "@size-limit/file": "^11.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "husky": "^9.0.0",
    "knip": "^5.0.0",
    "lint-staged": "^16.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "publint": "^0.3.0",
    "semantic-release": "^24.0.0",
    "size-limit": "^11.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "knip": {
    "ignoreDependencies": ["pino-pretty"]
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "30 kB"
    },
    {
      "path": "dist/context.js",
      "limit": "2 kB"
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
